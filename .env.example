# Postgres
POSTGRES_DB=woode_vpn
POSTGRES_USER=woode
POSTGRES_PASSWORD=change_me

# Backend
PORT=3000
APP_PUBLIC_BASE_URL=https://your-domain.com
APP_DOMAIN=your-domain.com
ADMIN_API_KEY=change_me_admin_api_key
IS_DEV=false
XUI_REQUEST_TIMEOUT_MS=10000
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_xxx_or_live_xxx
XUI_SERVERS_JSON=[{"id":"de-1","country":"DE","baseUrl":"https://de-panel.example.com/x5w5ObGMAQQBqb5cJv/","subscriptionUrl":"https://de-panel.example.com/x5w5ObGMAQQBqb5cJv/sub/ID","username":"admin","password":"password","publicHost":"de-vpn.example.com","inboundIds":[1],"enabled":true},{"id":"nl-1","country":"NL","baseUrl":"https://nl-panel.example.com/xQCLgogFhmGrwrUEqG/","subscriptionUrl":"https://nl-panel.example.com/xQCLgogFhmGrwrUEqG/sub/ID","username":"admin","password":"password","publicHost":"nl-panel.example.com","inboundIds":[2],"enabled":true}]

# Subscription delivery/runtime settings
TELEGRAM_LOGO_PATH=/app/logo.jpg
SUBSCRIPTION_PLAIN_RESPONSE=true
SUBSCRIPTION_REFRESH_FROM_XUI=true
SUBSCRIPTION_TITLE=Woode VPN
SUBSCRIPTION_SUPPORT_URL=https://t.me/woodemai
SUBSCRIPTION_PROFILE_URL=
SUBSCRIPTION_ANNOUNCE=Спасибо, что приняли участие в тестировании нашего VPN сервиса! По всем вопросам пишите в поддержку
SUBSCRIPTION_UPDATE_INTERVAL_HOURS=1
SUBSCRIPTION_TOTAL_BYTES=53687091200
TELEGRAM_NOTIFICATIONS_ENABLED=true

# Note: SUBSCRIPTION_TITLE/SUPPORT_URL/PROFILE_URL/ANNOUNCE/UPDATE_INTERVAL_HOURS
# are used only as initial defaults when SubscriptionConfig row (id=1) is created.
# After that, values are managed via /api/admin/subscription-config.

# Telegram bot
# Shared token used by both the bot and backend notifications
TELEGRAM_BOT_TOKEN=replace_with_botfather_token
BACKEND_BASE_URL=http://app:3000
BACKEND_REQUEST_TIMEOUT_MS=30000
TELEGRAM_HANDLER_TIMEOUT_MS=180000
BUY_DEFAULT_MONTHS=1
BUY_DEFAULT_COUNTRY=NL
