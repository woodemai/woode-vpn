generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

model User {
  id            Int            @id @default(autoincrement())
  externalId    String         @unique @default(cuid())
  telegramName  String         @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  vpnProfile    VpnProfile?
}

model Subscription {
  id                      Int                @id @default(autoincrement())
  userId                  Int
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                  SubscriptionStatus @default(ACTIVE)
  startsAt                DateTime
  endsAt                  DateTime
  paymentId               String?
  amountCents             Int?
  notified3DaysBefore     Boolean            @default(false)
  notified1DayBefore      Boolean            @default(false)
  notifiedAfterExpiration Boolean            @default(false)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([userId, status])
  @@index([status, endsAt])
  @@index([status, endsAt, notified3DaysBefore])
  @@index([status, endsAt, notified1DayBefore])
  @@index([status, endsAt, notifiedAfterExpiration])
}

model VpnProfile {
  id                 Int              @id @default(autoincrement())
  userId             Int              @unique
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionToken  String           @unique
  configs            Json?
  usageUploadBytes   BigInt           @default(0)
  usageDownloadBytes BigInt           @default(0)
  lastRefreshedAt    DateTime?
  hwidBindings       VpnHwidBinding[]
  active             Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model VpnHwidBinding {
  id          Int        @id @default(autoincrement())
  profileId   Int
  hwid        String     @db.VarChar(128)
  firstSeenAt DateTime   @default(now())
  lastSeenAt  DateTime   @default(now())
  profile     VpnProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, hwid])
}

model SubscriptionConfig {
  id                  Int      @id @default(1)
  title               String
  supportUrl          String?
  profileUrl          String?
  announce            String
  updateIntervalHours Int
  updatedAt           DateTime @updatedAt
}

model XuiServer {
  id              Int     @id @default(autoincrement())
  host            String  @unique
  port            Int
  webBasePath     String
  name            String
  country         String
  username        String
  password        String
  publicHost      String
  enabled         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
